{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noEmit": true,
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
