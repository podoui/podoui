== [react5] A6 Radio ==
$ npx agent-browser --session react5 click \[data-testid=radio-a\]
Ôťô Done
$ npx agent-browser --session react5 eval \'picked:\ \'\ +\ document.querySelector\(\'\[data-testid=radio-value\]\'\).textContent
"picked: apple"
$ npx agent-browser --session react5 click \[data-testid=radio-c\]
Ôťô Done
$ npx agent-browser --session react5 eval JSON.stringify\(\{picked:document.querySelector\(\'\[data-testid=radio-value\]\'\).textContent\,\ a:document.querySelector\(\'\[data-testid=radio-a\]\'\).checked\,\ c:document.querySelector\(\'\[data-testid=radio-c\]\'\).checked\}\)
"{\"picked\":\"peach\",\"a\":false,\"c\":true}"
$ npx agent-browser --session react5 eval \(\(\)\ =\>\ \{\ const\ d=document.querySelector\(\'\[data-testid=radio-d\]\'\)\;\ const\ l=d.closest\(\'label\'\)\|\|d.parentElement\;\ l.scrollIntoView\(\{block:\'center\'\}\)\;\ const\ r=l.getBoundingClientRect\(\)\;\ return\ JSON.stringify\(\{disabled:d.disabled\,\ cx:Math.round\(r.x+r.width/2\)\,\ cy:Math.round\(r.y+r.height/2\)\}\)\;\ \}\)\(\)
"{\"disabled\":true,\"cx\":479,\"cy\":450}"
$ npx agent-browser --session react5 mouse move 479 450
Ôťô Done
$ npx agent-browser --session react5 mouse down left
Ôťô Done
$ npx agent-browser --session react5 mouse up left
Ôťô Done
$ npx agent-browser --session react5 eval JSON.stringify\(\{note:\'after\ real\ mouse\ click\ on\ disabled\ radio\'\,\ picked:document.querySelector\(\'\[data-testid=radio-value\]\'\).textContent\,\ d:document.querySelector\(\'\[data-testid=radio-d\]\'\).checked\}\)
"{\"note\":\"after real mouse click on disabled radio\",\"picked\":\"peach\",\"d\":false}"
