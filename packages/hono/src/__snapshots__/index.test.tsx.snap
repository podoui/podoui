// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@podo/hono > renders button, icon, typography, and critical css helpers 1`] = `"<style data-podo-critical="true">.podo-button{color:var(--podo-component-button-text)}</style><script data-podo-theme="true">document.documentElement.dataset.podoTheme="dashboard";document.documentElement.dataset.colorScheme="dark";</script><button class="podo-button" type="button" data-theme="outline-primary" data-size="md"><span class="podo-button__icon"><i class="podo-icon podo-icon-menu" aria-hidden="true"></i></span><span class="podo-button__label">Save</span></button><button class="podo-chip" type="button" data-theme="outline-weak" data-size="lg"><span class="podo-chip__label">필터</span><span class="podo-chip__suffix"><i class="podo-icon podo-icon-menu" aria-hidden="true"></i></span></button><button class="podo-switch" type="button" role="switch" aria-checked="true" aria-label="알림" data-size="lg" data-state="on"><span class="podo-switch__handle"></span></button><label class="podo-checkbox-wrap" data-size="md" data-bold="true"><input class="podo-checkbox" type="checkbox" data-state="indeterminate"/><span class="podo-checkbox__text">전체 선택</span></label><label class="podo-radio-wrap" data-size="lg"><input class="podo-radio" type="radio" name="plan" value="basic" checked=""/><span class="podo-radio__text">베이직</span></label><div class="podo-toast" role="status" data-state="warning"><div class="podo-toast__contents"><div class="podo-toast__title-row"><span class="podo-toast__title">저장 공간이 얼마 남지 않았어요</span><span class="podo-toast__suffix"><button class="podo-toast__close" type="button" aria-label="닫기"><svg aria-hidden="true" viewBox="0 0 24 24" width="24" height="24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button></span></div><span class="podo-toast__caption">캡션 영역</span></div></div><div class="podo-tooltip" role="tooltip" data-theme="reverse" data-position="top" data-ordinal="second"><span class="podo-tooltip__arrow"><svg aria-hidden="true" width="16" height="4" viewBox="0 0 16 4"><path d="M0 0h4l4 4 4-4h4z" fill="currentColor"/></svg></span><span class="podo-tooltip__bubble">임시 저장돼요</span></div><textarea class="podo-textarea" name="memo" aria-invalid="true" data-state="invalid" data-resize="false">메모</textarea><table class="podo-table" data-type="grid"><tbody><tr><td>#1024</td></tr></tbody></table><h1 class="podo-text podo-text--h1">Dashboard</h1>"`;
