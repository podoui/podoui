// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@podo/hono > renders button, icon, typography, and critical css helpers 1`] = `"<style data-podo-critical="true">.podo-button{color:var(--podo-component-button-text)}</style><script data-podo-theme="true">document.documentElement.dataset.podoTheme="dashboard";document.documentElement.dataset.colorScheme="dark";</script><button class="podo-button" type="button" data-theme="outline-primary" data-size="md"><span class="podo-button__icon"><i class="podo-icon podo-icon-menu" aria-hidden="true"></i></span><span class="podo-button__label">Save</span></button><button class="podo-chip" type="button" data-theme="outline-weak" data-size="sm"><span class="podo-chip__label">필터</span><span class="podo-chip__suffix"><i class="podo-icon podo-icon-menu" aria-hidden="true"></i></span></button><button class="podo-switch" type="button" role="switch" aria-checked="true" aria-label="알림" data-size="lg" data-state="on"><span class="podo-switch__handle"></span></button><label class="podo-checkbox-wrap" data-size="md" data-bold="true"><input class="podo-checkbox" type="checkbox" data-state="indeterminate"/><span class="podo-checkbox__text">전체 선택</span></label><textarea class="podo-textarea" name="memo" aria-invalid="true" data-state="invalid" data-resize="false">메모</textarea><table class="podo-table" data-type="grid"><tbody><tr><td>#1024</td></tr></tbody></table><h1 class="podo-text podo-text--h1">Dashboard</h1>"`;
