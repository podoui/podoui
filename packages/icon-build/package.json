{
  "name": "@podoui/icon-build",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Deterministic, isomorphic SVG-to-woff2 icon font builder for browser and Node icon builds.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@podoui/spec": "workspace:*",
    "opentype.js": "2.0.0",
    "svgpath": "2.6.0",
    "woff2-encoder": "2.0.0"
  },
  "author": "hada0127 <work@tarucy.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hada0127/podo-ui.git",
    "directory": "packages/icon-build"
  },
  "homepage": "https://podoui.com",
  "bugs": {
    "url": "https://github.com/hada0127/podo-ui/issues"
  }
}
