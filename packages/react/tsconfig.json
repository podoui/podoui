{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    // ponytail: v1에서 포팅한 datepicker/editor 소스가 인덱스 접근 검사를
    // 통과하도록 완화 — 신규 코드가 안정화되면 다시 켠다.
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.figma.tsx"],
  "references": [{ "path": "../core" }]
}
