// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`@podoui/react > snapshots themed variant markup for visual regression 1`] = `
<div
  data-color-scheme="dark"
  data-podo-theme="dashboard"
>
  <button
    class="podo-button"
    data-size="lg"
    data-theme="solid-assistive"
    type="button"
  >
    <span
      class="podo-button__icon"
    >
      <i
        aria-hidden="true"
        class="podo-icon podo-icon-menu"
      />
    </span>
    <span
      class="podo-button__label"
    >
      Save
    </span>
  </button>
  <div
    class="podo-field"
    data-invalid="true"
  >
    <div
      class="podo-field__heading"
    >
      <label
        class="podo-field__label"
        for="email-control"
        id="email-label"
      >
        Email
        <span
          class="podo-field__sub-label"
        >
          선택
        </span>
      </label>
      <span
        class="podo-field__suffix-icon"
      >
        <i
          aria-hidden="true"
          class="podo-icon podo-icon-menu"
        />
      </span>
    </div>
    <div
      class="podo-field__control"
    >
      <div
        class="podo-input"
        data-size="lg"
        data-state="invalid"
      >
        <span
          class="podo-input__prefix"
        >
          <i
            aria-hidden="true"
            class="podo-icon podo-icon-menu"
          />
        </span>
        <input
          aria-describedby="email-description"
          aria-invalid="true"
          aria-label="Email"
          aria-labelledby="email-label"
          class="podo-input__control"
          id="email-control"
          maxlength="500"
        />
        <span
          class="podo-input__suffix-text"
        >
          @podo.dev
        </span>
      </div>
    </div>
    <div
      class="podo-field__footer"
    >
      <span
        class="podo-field__helper-text"
        id="email-description"
      >
        Work email
      </span>
      <span
        class="podo-field__count"
      >
        0
        /
        500
      </span>
    </div>
  </div>
</div>
`;
