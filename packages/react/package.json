{
  "name": "@podo/react",
  "version": "0.0.0",
  "type": "module",
  "description": "React runtime and typed component exports for Podo.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@podo/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
