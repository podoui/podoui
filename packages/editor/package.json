{
  "name": "@podo/editor",
  "version": "0.0.0",
  "type": "module",
  "description": "Design-system development editor for Podo specs.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "vite",
    "preview": "vite preview",
    "gen:default-icons": "tsx scripts/generate-default-icons.mts",
    "gen:default-icons:check": "tsx scripts/generate-default-icons.mts --check",
    "gen:v1-css": "node scripts/vendor-v1-css.mjs"
  },
  "dependencies": {
    "@podo/edit-core": "workspace:*",
    "@podo/icon-build": "workspace:*",
    "@podo/spec": "workspace:*",
    "opentype.js": "2.0.0",
    "paper": "0.12.18",
    "tldraw": "^5.1.0",
    "uuid": "^14.0.0",
    "woff2-encoder": "^2.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@podo/tokens": "workspace:*",
    "@types/uuid": "^11.0.0",
    "sass": "^1.101.0",
    "tsx": "^4.20.6",
    "vite": "^8.0.16"
  }
}
