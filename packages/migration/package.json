{
  "name": "@podo/migration",
  "version": "0.0.0",
  "type": "module",
  "description": "Migration manifest, JSON Patch runner, and conflict detection for Podo projects.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
