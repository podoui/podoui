{
  "name": "@podoui/tokens",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Token loading, merging, resolving, and target emitters for Podo.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@podoui/spec": "workspace:*"
  },
  "author": "hada0127 <work@tarucy.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/podoui/podoui.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://podoui.com",
  "bugs": {
    "url": "https://github.com/podoui/podoui/issues"
  }
}
