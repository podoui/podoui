{
  "schemaVersion": "2.0.0",
  "kind": "component",
  "id": "chip",
  "name": "Chip",
  "category": "atom",
  "status": "experimental",
  "description": "Compact selectable tag (Figma 538:6615) with a selection model — unselected is the base look. solid: gray.10 fill unselected, gray.70 fill with gray.0 text selected; outline-strong/weak: transparent with a gray.20 hairline unselected (outline-strong selected currently renders identically to solid, pending a design fix; outline-weak selected is gray.5 with a gray.50 border). Pressing nudges each state darker (unselected-pressed, selected-pressed) and disabled flattens to gray.20/gray.40. Sizes: md 14px/2-6 padding (base), lg 16px/2-8. prefix and suffix icon slots compose category and remove actions.",
  "anatomy": [
    {
      "name": "root"
    },
    {
      "name": "prefix-icon",
      "parent": "root"
    },
    {
      "name": "label",
      "parent": "root"
    },
    {
      "name": "suffix-icon",
      "parent": "root"
    }
  ],
  "slots": [
    {
      "name": "prefix-icon",
      "description": "Category/status icon before the label.",
      "targets": {
        "web": {
          "name": "prefix"
        },
        "react": {
          "name": "prefix"
        },
        "hono": {
          "name": "prefix"
        },
        "native": {
          "name": "prefix"
        }
      }
    },
    {
      "name": "children",
      "required": true,
      "fallback": "Label"
    },
    {
      "name": "suffix-icon",
      "description": "Removal/action icon after the label (e.g. close).",
      "targets": {
        "web": {
          "name": "suffix"
        },
        "react": {
          "name": "suffix"
        },
        "hono": {
          "name": "suffix"
        },
        "native": {
          "name": "suffix"
        }
      }
    }
  ],
  "props": [
    {
      "name": "selected",
      "type": {
        "kind": "boolean"
      },
      "default": false,
      "description": "선택 여부 (Figma state) — 비선택이 기본 모습. 지정하면 aria-pressed로 안내."
    },
    {
      "name": "disabled",
      "type": {
        "kind": "boolean"
      },
      "default": false
    },
    {
      "name": "onPress",
      "type": {
        "kind": "event",
        "payload": {
          "source": "chip"
        }
      }
    }
  ],
  "variants": [
    {
      "name": "theme",
      "values": ["solid", "outline-strong", "outline-weak"],
      "default": "solid",
      "valueTokens": {
        "solid": {
          "root.background": "{color.palette.gray.70}",
          "label.color": "{color.palette.gray.0}"
        },
        "outline-strong": {
          "root.background": "{color.palette.gray.70}",
          "label.color": "{color.palette.gray.0}"
        },
        "outline-weak": {
          "root.background": "{color.palette.gray.5}",
          "root.borderColor": "{color.palette.gray.50}",
          "label.color": "{color.palette.gray.90}"
        }
      }
    },
    {
      "name": "size",
      "values": ["md", "lg"],
      "default": "md"
    }
  ],
  "states": [
    {
      "name": "focusVisible"
    },
    {
      "name": "selected",
      "description": "Figma selected: the filled look (solid/outline-strong gray.70 + gray.0 text, outline-weak gray.5 + gray.50 border)."
    },
    {
      "name": "active",
      "description": "Figma unselected-pressed/selected-pressed press feedback per theme."
    },
    {
      "name": "disabled",
      "tokens": {
        "root.background": "{color.palette.gray.20}",
        "label.color": "{color.palette.gray.40}"
      }
    }
  ],
  "tokens": {
    "root.background": "{color.palette.gray.10}",
    "label.color": "{color.palette.gray.90}"
  },
  "targets": {
    "web": {
      "supported": true,
      "limitations": []
    },
    "react": {
      "supported": true,
      "limitations": []
    },
    "hono": {
      "supported": true,
      "limitations": ["Press handling requires client code."]
    },
    "native": {
      "supported": true,
      "limitations": []
    }
  },
  "accessibility": {
    "aria": ["aria-disabled", "aria-pressed when selected is provided"],
    "keyboard": ["Enter/Space activates the chip"],
    "focusManagement": "Chip is a native button; focus follows the platform."
  },
  "examples": [
    {
      "target": "react",
      "title": "Removable filter chip",
      "code": "<Chip suffix={<CloseIcon />} onPress={removeFilter}>필터명</Chip>"
    }
  ]
}
