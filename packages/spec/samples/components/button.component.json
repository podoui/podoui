{
  "schemaVersion": "2.0.0",
  "kind": "component",
  "id": "button",
  "name": "Button",
  "category": "atom",
  "status": "stable",
  "description": "Action button with themed solid/outline treatments, sizes, and prefix/suffix icon slots.",
  "anatomy": [
    {
      "name": "root",
      "targets": {
        "web": "button",
        "react": "button",
        "hono": "button",
        "native": "Pressable"
      }
    },
    {
      "name": "prefix",
      "targets": {
        "web": "slot[name=prefix]",
        "react": "prefix",
        "native": "prefix"
      }
    },
    {
      "name": "label",
      "targets": {
        "web": "slot",
        "react": "children",
        "hono": "children",
        "native": "Text"
      }
    },
    {
      "name": "suffix",
      "targets": {
        "web": "slot[name=suffix]",
        "react": "suffix",
        "native": "suffix"
      }
    }
  ],
  "slots": [
    {
      "name": "prefix",
      "targets": {
        "web": {
          "name": "prefix"
        },
        "react": {
          "name": "prefix"
        },
        "native": {
          "name": "prefix"
        }
      }
    },
    {
      "name": "children",
      "required": true,
      "targets": {
        "web": {
          "name": "default"
        },
        "react": {
          "name": "children"
        },
        "hono": {
          "name": "children"
        },
        "native": {
          "name": "children"
        }
      }
    },
    {
      "name": "suffix",
      "targets": {
        "web": {
          "name": "suffix"
        },
        "react": {
          "name": "suffix"
        },
        "native": {
          "name": "suffix"
        }
      }
    }
  ],
  "props": [
    {
      "name": "theme",
      "type": {
        "kind": "enum",
        "values": [
          "solid-primary",
          "solid-assistive",
          "solid-white",
          "solid-danger",
          "outline-primary",
          "outline-assistive",
          "outline-white",
          "outline-danger"
        ]
      },
      "default": "solid-primary",
      "description": "Form (solid/outline) and tone (primary/assistive/white/danger) treatment."
    },
    {
      "name": "size",
      "type": {
        "kind": "enum",
        "values": ["xs", "sm", "md", "lg"]
      },
      "default": "md",
      "description": "Control height, padding, font size, and radius (xs 32, sm 36, md 42, lg 52)."
    },
    {
      "name": "disabled",
      "type": {
        "kind": "boolean"
      },
      "default": false
    },
    {
      "name": "fill",
      "type": {
        "kind": "boolean"
      },
      "default": false,
      "description": "Stretch to the parent's full width (Figma auto-layout fill container)."
    },
    {
      "name": "onPress",
      "type": {
        "kind": "event",
        "payload": {
          "source": "button"
        }
      },
      "description": "Target-neutral activation event."
    }
  ],
  "variants": [
    {
      "name": "theme",
      "values": [
        "solid-primary",
        "solid-assistive",
        "solid-white",
        "solid-danger",
        "outline-primary",
        "outline-assistive",
        "outline-white",
        "outline-danger"
      ],
      "default": "solid-primary",
      "tokens": {
        "root.background": "{component.button.background}",
        "label.color": "{component.button.text}"
      },
      "valueTokens": {
        "solid-primary": {
          "root.background": "{component.button.solid-primary.background}",
          "label.color": "{component.button.solid-primary.text}"
        },
        "solid-assistive": {
          "root.background": "{component.button.solid-assistive.background}",
          "label.color": "{component.button.solid-assistive.text}"
        },
        "solid-white": {
          "root.background": "{component.button.solid-white.background}",
          "label.color": "{component.button.solid-white.text}"
        },
        "solid-danger": {
          "root.background": "{component.button.solid-danger.background}",
          "label.color": "{component.button.solid-danger.text}"
        },
        "outline-primary": {
          "root.background": "{component.button.outline-primary.background}",
          "root.borderColor": "{component.button.outline-primary.border}",
          "label.color": "{component.button.outline-primary.text}"
        },
        "outline-assistive": {
          "root.background": "{component.button.outline-assistive.background}",
          "root.borderColor": "{component.button.outline-assistive.border}",
          "label.color": "{component.button.outline-assistive.text}"
        },
        "outline-white": {
          "root.background": "{component.button.outline-white.background}",
          "root.borderColor": "{component.button.outline-white.border}",
          "label.color": "{component.button.outline-white.text}"
        },
        "outline-danger": {
          "root.background": "{component.button.outline-danger.background}",
          "root.borderColor": "{component.button.outline-danger.border}",
          "label.color": "{component.button.outline-danger.text}"
        }
      }
    },
    {
      "name": "size",
      "values": ["xs", "sm", "md", "lg"],
      "default": "md"
    }
  ],
  "states": [
    {
      "name": "hover",
      "description": "Pointer hover affordance."
    },
    {
      "name": "active",
      "description": "Pressed state (Figma 'pressed')."
    },
    {
      "name": "focusVisible",
      "description": "Keyboard focus ring."
    },
    {
      "name": "disabled",
      "description": "Unavailable action."
    }
  ],
  "tokens": {
    "root.background": "{component.button.background}",
    "label.color": "{component.button.text}",
    "icon.color": "{component.button.text}"
  },
  "targets": {
    "web": {
      "supported": true,
      "limitations": []
    },
    "react": {
      "supported": true,
      "limitations": []
    },
    "hono": {
      "supported": true,
      "limitations": ["Events render as attributes only in SSR output."]
    },
    "native": {
      "supported": true,
      "limitations": ["Slots map to named props."]
    }
  },
  "accessibility": {
    "role": "button",
    "aria": ["aria-disabled"],
    "keyboard": ["Enter activates", "Space activates"],
    "focusManagement": "Use focus-visible state for keyboard focus."
  },
  "examples": [
    {
      "target": "react",
      "title": "Primary action",
      "code": "<Button theme=\"solid-primary\">Save</Button>"
    },
    {
      "target": "web",
      "title": "Web component",
      "code": "<podo-button theme=\"solid-primary\">Save</podo-button>"
    }
  ]
}
