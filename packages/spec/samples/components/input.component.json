{
  "schemaVersion": "2.0.0",
  "kind": "component",
  "id": "input",
  "name": "Input",
  "category": "atom",
  "status": "stable",
  "description": "Text input (Figma 538:6693): md/lg sizes, normal/hover/focused/completed/danger/disabled states, and prefix, suffix-text, suffix-icon composition slots.",
  "anatomy": [
    { "name": "root" },
    { "name": "prefix", "parent": "root" },
    {
      "name": "control",
      "parent": "root",
      "targets": { "web": "input", "react": "input", "hono": "input", "native": "TextInput" }
    },
    { "name": "suffix-text", "parent": "root" },
    { "name": "suffix-icon", "parent": "root" }
  ],
  "slots": [
    {
      "name": "prefix",
      "description": "Icon or symbol giving the value context, before the control.",
      "targets": {
        "web": { "name": "prefix" },
        "react": { "name": "prefix" },
        "hono": { "name": "prefix" },
        "native": { "name": "prefix" }
      }
    },
    {
      "name": "suffix-text",
      "description": "Fixed unit/domain text after the control (원, kg, @domain).",
      "targets": {
        "web": { "name": "suffix-text" },
        "react": { "name": "suffixText" },
        "hono": { "name": "suffixText" },
        "native": { "name": "suffixText" }
      }
    },
    {
      "name": "suffix-icon",
      "description": "In-input action icon: clear, search, visibility toggle.",
      "targets": {
        "web": { "name": "suffix-icon" },
        "react": { "name": "suffixIcon" },
        "hono": { "name": "suffixIcon" },
        "native": { "name": "suffixIcon" }
      }
    }
  ],
  "props": [
    { "name": "value", "type": { "kind": "string" }, "description": "Controlled value." },
    {
      "name": "default-value",
      "type": { "kind": "string" },
      "description": "Initial uncontrolled value."
    },
    { "name": "placeholder", "type": { "kind": "string" } },
    { "name": "invalid", "type": { "kind": "boolean" }, "default": false },
    { "name": "disabled", "type": { "kind": "boolean" }, "default": false },
    { "name": "required", "type": { "kind": "boolean" }, "default": false },
    { "name": "onValueChange", "type": { "kind": "event", "payload": { "value": "string" } } }
  ],
  "variants": [{ "name": "size", "values": ["md", "lg"], "default": "md" }],
  "states": [
    { "name": "focusVisible" },
    { "name": "disabled" },
    { "name": "invalid", "tokens": { "root.borderColor": "{semantic.color.text.danger}" } }
  ],
  "tokens": {
    "root.background": "{component.input.background}",
    "root.borderColor": "{component.input.border}",
    "text.color": "{semantic.color.text.default}",
    "suffix-text.color": "{semantic.color.text.subtle}"
  },
  "targets": {
    "web": { "supported": true, "limitations": [] },
    "react": { "supported": true, "limitations": [] },
    "hono": { "supported": true, "limitations": ["Value changes require client code."] },
    "native": {
      "supported": true,
      "limitations": ["Native keyboard options are target-specific props."]
    }
  },
  "accessibility": {
    "aria": ["aria-invalid", "aria-required", "aria-describedby"],
    "keyboard": ["Tab focuses the input"],
    "focusManagement": "Expose focus ref on React and native targets."
  },
  "examples": [
    {
      "target": "react",
      "title": "Amount input with unit suffix",
      "code": "<Input size=\"lg\" suffixText=\"원\" placeholder=\"금액을 입력해 주세요\" />"
    }
  ]
}
