                "scope": "primitive",
                "roles": ["brand", "action"]
              }
            }
          }
        },
        "gray": {
          "0": {
            "$type": "color",
            "$value": "#FFFFFF",
            "$extensions": {
              "podo": {
                "scope": "primitive",
                "roles": ["surface"]
              }
            }
          },
          "900": {
            "$type": "color",
            "$value": "#14151A",
            "$extensions": {
              "podo": {
                "scope": "primitive",
                "roles": ["text"]
              }
            }
          }
        },
        "red": {
          "600": {
            "$type": "color",
            "$value": "#D92D20",
            "$extensions": {
