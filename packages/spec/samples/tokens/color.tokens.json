                "scope": "primitive",
                "roles": ["danger"]
              }
            }
          }
        }
      }
    },
    "semantic": {
      "color": {
        "text": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.gray.900}",
            "$extensions": {
              "podo": {
                "themeable": true,
                "scope": "semantic",
                "roles": ["text"]
              }
            }
          },
          "inverse": {
            "$type": "color",
            "$value": "{color.palette.gray.0}",
