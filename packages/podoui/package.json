{
  "name": "podoui",
  "version": "0.0.0",
  "type": "module",
  "description": "Podo design system CLI entry (npx podoui) — interactive menu over @podo/cli.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "podoui": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@podo/cli": "workspace:*"
  }
}
