{
  "name": "@podoui/mcp",
  "version": "2.0.0",
  "type": "module",
  "description": "Model Context Protocol server for Podo specs.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "podo-mcp": "./dist/index.js"
  },
