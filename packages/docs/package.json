{
  "name": "@podoui/docs",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Podo UI documentation site. Renders live @podoui/react components.",
  "scripts": {
    "predev": "tsc -b ../core ../react",
    "dev": "vite",
    "prebuild": "tsc -b ../core ../react",
    "build": "vite build",
    "typecheck": "tsc -b tsconfig.json",
    "preview": "vite preview",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@podoui/react": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "podo-ui": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
