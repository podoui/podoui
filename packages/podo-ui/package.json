{
  "name": "podo-ui",
  "version": "2.0.0",
  "type": "module",
  "description": "Podo UI v2 — JSON-spec-first design system for web, React, Hono, and React Native. Meta package over @podoui/*.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./spec": {
      "types": "./dist/spec.d.ts",
      "import": "./dist/spec.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@podoui/core": "workspace:*",
    "@podoui/hono": "workspace:*",
    "@podoui/icons": "workspace:*",
    "@podoui/native": "workspace:*",
    "@podoui/react": "workspace:*",
    "@podoui/spec": "workspace:*",
    "@podoui/tokens": "workspace:*",
    "@podoui/web": "workspace:*"
  },
  "author": "hada0127 <work@tarucy.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hada0127/podo-ui.git",
    "directory": "packages/podo-ui"
  },
  "homepage": "https://podoui.com",
  "bugs": {
    "url": "https://github.com/hada0127/podo-ui/issues"
  }
}
