{
  "name": "podo-ui-v2-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "author": "hada0127 <work@tarucy.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hada0127/podo-ui.git"
  },
  "bugs": {
    "url": "https://github.com/hada0127/podo-ui/issues"
  },
  "homepage": "https://podoui.com",
  "scripts": {
    "build": "pnpm clean && pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean && rm -rf dist coverage .turbo",
    "examples:build": "pnpm --filter './examples/*' build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "figma:check": "figma connect parse",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check && pnpm figma:check",
    "release:verify": "node scripts/verify-release.mjs",
    "changeset:dry-run": "changeset status --verbose && pnpm --filter './packages/*' pack --dry-run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm check && pnpm build && pnpm release:verify && pnpm changeset:dry-run && pnpm --filter podo-ui --filter podoui publish --access public",
    "prepublishOnly": "pnpm check && pnpm build && pnpm release:verify && pnpm changeset:dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.1",
    "@figma/code-connect": "^1.4.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.15"
  }
}
